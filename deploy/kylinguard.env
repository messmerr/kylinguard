# KylinGuard systemd 生产配置。该文件只放运行边界，不保存模型 API Key；
# 模型凭据由 Web 界面写入仅控制面账户可读的 secrets 目录。
KG_DB_PATH=/var/lib/kylinguard/db/kylinguard.db
KG_FRONTEND_DIST=/opt/kylinguard/current/frontend
KG_LLM_SECRETS_DIR=/var/lib/kylinguard/secrets/llm
KG_MCP_SECRETS_DIR=/var/lib/kylinguard/secrets/mcp
KG_SKILLS_DIR=/var/lib/kylinguard/skills
KG_SKILLS_STATE_PATH=/var/lib/kylinguard/skills-state.json

# 控制面 kylinguard 与执行面 kylinguard-exec 分离。工作目录只向这两个账户开放。
KG_WORKSPACE_ROOT=/srv/kylinguard-workspace
KG_EXEC_USER=kylinguard-exec
KG_COMMAND_SHELL=/bin/bash
KG_PRIVILEGED_HELPER=/usr/local/libexec/kylinguard/kylinguard-privileged

KG_COMMAND_TIMEOUT=30
KG_COMMAND_MAX_TIMEOUT=900
KG_OUTPUT_MAX_BYTES=65536
KG_PERMISSION_DEFAULT_TTL=1800
KG_ALLOW_FULL_ACCESS=true
KG_SNAPSHOT_INTERVAL=30
