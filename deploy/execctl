#!/usr/bin/env bash
set -euo pipefail

die() {
  echo "拒绝：$*" >&2
  exit 64
}

valid_name() {
  [[ "$1" =~ ^[A-Za-z0-9_.@:-]+$ ]]
}

check_service_allowlist() {
  local unit="$1"
  local allow="/etc/kylinguard/allowed-services"
  # 白名单是提权边界的一部分。文件缺失或不可读时必须 fail closed，
  # 不能把部署疏漏解释成“允许控制任意服务”。
  [ -r "$allow" ] || return 1
  grep -Fx -- "$unit" "$allow" >/dev/null 2>&1
}

case "${1:-}" in
  service)
    action="${2:-}"
    unit="${3:-}"
    [ "$#" -eq 3 ] || die "service 参数必须为：service <start|restart|stop> <unit>"
    case "$action" in start|restart|stop) ;; *) die "非法 service 动作：$action" ;; esac
    valid_name "$unit" || die "非法服务名：$unit"
    check_service_allowlist "$unit" || die "服务未在 /etc/kylinguard/allowed-services 白名单内：$unit"
    exec /usr/bin/systemctl "$action" "$unit"
    ;;
  clean-file)
    path="${2:-}"
    [ "$#" -eq 2 ] || die "clean-file 参数必须为：clean-file <path>"
    [ -n "$path" ] || die "路径为空"
    # 不能用 realpath/-f 检查后再让 root 按字符串 rm：攻击者可在两次
    # 系统调用之间把父目录替换为符号链接。这里逐级以 O_NOFOLLOW 打开
    # 目录，并最终相对已持有的 parent dirfd 执行 unlinkat 语义的删除。
    /usr/bin/python3 - "$path" <<'PY'
import os
import stat
import sys


def refuse(message: str) -> None:
    print(f"拒绝：{message}", file=sys.stderr)
    raise SystemExit(64)


raw = sys.argv[1]
if not os.path.isabs(raw) or "\x00" in raw:
    refuse("clean-file 只接受不含 NUL 的绝对路径")
path = os.path.normpath(raw)
allowed = ("/tmp", "/var/tmp", "/var/cache", "/var/log")
if not any(path.startswith(prefix + "/") for prefix in allowed):
    refuse(f"清理路径不在白名单目录内：{path}")

parts = [part for part in path.split("/") if part]
if not parts:
    refuse("路径为空")
flags = os.O_RDONLY | os.O_DIRECTORY | getattr(os, "O_CLOEXEC", 0)
nofollow = getattr(os, "O_NOFOLLOW", 0)
directory_fd = os.open("/", flags)
try:
    for component in parts[:-1]:
        try:
            next_fd = os.open(
                component, flags | nofollow, dir_fd=directory_fd
            )
        except OSError as exc:
            refuse(f"父目录不可安全打开：{component}（{exc.strerror}）")
        os.close(directory_fd)
        directory_fd = next_fd
    leaf = parts[-1]
    try:
        info = os.stat(leaf, dir_fd=directory_fd, follow_symlinks=False)
    except OSError as exc:
        refuse(f"目标不可访问：{leaf}（{exc.strerror}）")
    if not stat.S_ISREG(info.st_mode):
        refuse(f"只允许删除普通文件：{path}")
    try:
        os.unlink(leaf, dir_fd=directory_fd)
        os.fsync(directory_fd)
    except OSError as exc:
        refuse(f"删除失败：{leaf}（{exc.strerror}）")
finally:
    os.close(directory_fd)
PY
    ;;
  *)
    die "未知动作：${1:-}"
    ;;
esac
