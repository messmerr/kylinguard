# KylinGuard 可选配置。应用使用内置默认值即可启动；仅在需要覆盖时复制为 .env。
# 模型提供商、API Key、可用模型和默认模型统一在“模型服务”页面配置。

# 单次模型请求超时（秒）
KG_LLM_TIMEOUT=60

# SQLite 数据库。请从仓库根目录启动，以便相对路径稳定落在 data/。
KG_DB_PATH=data/kylinguard.db

# Agent 默认工作目录；未设置时使用仓库根目录
# KG_WORKSPACE_ROOT=/path/to/workspace

# 命令执行配置
KG_COMMAND_SHELL=/bin/bash
KG_COMMAND_TIMEOUT=30
KG_COMMAND_MAX_TIMEOUT=900

# 是否允许管理员在界面中揭示完全访问入口
KG_ALLOW_FULL_ACCESS=true

# 会话内普通动作授权的默认有效期（秒）
KG_PERMISSION_DEFAULT_TTL=1800
