# 麒盾 KylinGuard 配置模板：复制为 .env 并填入真实值（.env 已 gitignore，勿入库）
KG_LLM_BASE_URL=https://api.deepseek.com
KG_LLM_API_KEY=sk-你的密钥
KG_PLANNER_MODEL=deepseek-v4-pro
KG_REVIEWER_MODEL=deepseek-v4-pro
# 单次模型请求超时（秒）；超时、限流和 5xx 会按界面可见的策略重试
KG_LLM_TIMEOUT=60
KG_DB_PATH=data/kylinguard.db
# Docker 启动时会在 compose 中覆盖为 /app/data/kylinguard.db，并挂载到命名卷
# 生产环境启用专用执行账户（需配 sudoers 白名单）；开发环境留空
KG_EXEC_USER=
KG_PRIVILEGED_HELPER=
# 完全访问只跳过逐项确认，不提升系统权限；必须搭配独立的非 root KG_EXEC_USER
KG_ALLOW_FULL_ACCESS=false
KG_PERMISSION_DEFAULT_TTL=1800
KG_PERMISSION_MAX_TTL=43200
KG_FULL_ACCESS_MAX_TTL=1800
# 管理员账户（首次启动时创建；密码留空则无法登录）
KG_ADMIN_USER=admin
KG_ADMIN_PASSWORD=请设置强密码
